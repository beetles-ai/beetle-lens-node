# ── Beetle Lens SDK config ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values

# Kafka mode (direct publish — used when running beetle-lens-server consumer)
KAFKA_BROKERS=3.111.217.78:9092

# HTTP ingest mode (used when Kafka is not set — sends to beetle-lens-server API)
# BEETLE_API_KEY=blt_svc_your_key_here
# BEETLE_ENDPOINT=http://localhost:3001
