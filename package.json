{
  "name": "@beetleai_dev/lens-node",
  "version": "1.0.0",
  "description": "Production profiler for Node.js Express apps — tracks route latency, DB queries, and HTTP calls. Shows real metrics inline in VS Code via Beetle Lens.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "profiler",
    "performance",
    "monitoring",
    "express",
    "mongoose",
    "apm",
    "tracing",
    "codelens",
    "vscode",
    "beetle"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "author": "Beetle AI",
  "repository": {
    "type": "git",
    "url": "https://github.com/beetles-ai/beetle-lens-node"
  },
  "homepage": "https://github.com/beetles-ai/beetle-lens-node#readme",
  "dependencies": {
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": { "optional": false }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
